<%- include('partials/head', { title: 'Report an Issue' }) %>

<div class="citizen-shell">

  <!-- ── HEADER ──────────────────────────────────────────────── -->
  <div class="citizen-header">
    <a href="/"
       style="width:36px;height:36px;border-radius:10px;background:rgba(139,92,246,.08);border:1px solid rgba(139,92,246,.2);display:flex;align-items:center;justify-content:center;color:var(--violet-400);text-decoration:none;transition:all .15s;flex-shrink:0"
       onmouseover="this.style.background='rgba(139,92,246,.18)'"
       onmouseout="this.style.background='rgba(139,92,246,.08)'">
      <i class="fa-solid fa-arrow-left" style="font-size:13px"></i>
    </a>
    <div>
      <h1 style="font-size:17px;font-weight:700;color:var(--text-primary);letter-spacing:-.3px;font-family:'Space Grotesk',sans-serif">Report an Issue</h1>
      <p style="font-size:11px;color:var(--text-tertiary);margin-top:1px">Help keep the city clean</p>
    </div>
    <div style="margin-left:auto">
      <span class="badge badge-info"><i class="fa-solid fa-shield-halved" style="margin-right:3px"></i>Public</span>
    </div>
  </div>

  <!-- ── BODY ────────────────────────────────────────────────── -->
  <div class="citizen-body">

    <!-- SUCCESS STATE (hidden by default) -->
    <div id="success-screen" class="hidden" style="text-align:center;padding:64px 20px">
      <div style="width:88px;height:88px;background:var(--grad-brand);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:38px;color:white;margin:0 auto 22px;animation:bounceIn .5s cubic-bezier(0.34,1.56,0.64,1);box-shadow:0 0 40px rgba(139,92,246,.4)">
        <i class="fa-solid fa-circle-check"></i>
      </div>
      <h2 style="font-size:24px;font-weight:700;color:var(--text-primary);margin-bottom:8px;font-family:'Space Grotesk',sans-serif">Report Submitted!</h2>
      <p style="color:var(--text-secondary);font-size:14px;margin-bottom:8px">Your report has been received and assigned to the nearest team.</p>
      <p style="color:var(--text-tertiary);font-size:12px;margin-bottom:30px">Typical resolution time: <strong style="color:var(--violet-400)">2–4 hours</strong></p>
      <div class="flex gap-3 justify-center">
        <button class="btn btn-secondary" onclick="resetForm()"><i class="fa-solid fa-plus"></i> Submit Another</button>
        <a href="/" class="btn btn-primary"><i class="fa-solid fa-house"></i> Back to Home</a>
      </div>
    </div>

    <!-- FORM -->
    <div id="report-form-wrapper">

      <!-- Hero -->
      <div class="report-hero">
        <div class="report-hero-icon">
          <i class="fa-solid fa-bullhorn"></i>
        </div>
        <h2 class="report-hero-title">Spot Garbage? Report It.</h2>
        <p class="report-hero-sub">Help us keep Navi Mumbai clean by reporting missed or overflowing bins near you.</p>
      </div>

      <!-- Form -->
      <form id="report-form" novalidate>

        <!-- Issue Type -->
        <div class="form-group">
          <label class="form-label">Issue Type <span style="color:var(--pink-400)">*</span></label>
          <div class="issue-grid">
            <button type="button" class="issue-btn" data-issue="Overflowing Bin" onclick="selectIssue(this)">
              <i class="fa-solid fa-dumpster-fire" style="display:block;font-size:20px;margin-bottom:8px;color:var(--amber-400)"></i>
              Overflowing Bin
            </button>
            <button type="button" class="issue-btn" data-issue="Missed Collection" onclick="selectIssue(this)">
              <i class="fa-solid fa-truck-ramp-box" style="display:block;font-size:20px;margin-bottom:8px;color:var(--pink-400)"></i>
              Missed Collection
            </button>
            <button type="button" class="issue-btn" data-issue="Damaged Bin" onclick="selectIssue(this)">
              <i class="fa-solid fa-trash-can" style="display:block;font-size:20px;margin-bottom:8px;color:var(--cyan-400)"></i>
              Damaged Bin
            </button>
            <button type="button" class="issue-btn" data-issue="Illegal Dumping" onclick="selectIssue(this)">
              <i class="fa-solid fa-ban" style="display:block;font-size:20px;margin-bottom:8px;color:var(--red-400)"></i>
              Illegal Dumping
            </button>
          </div>
          <input type="hidden" id="selected-issue" name="issueType">
          <p id="issue-error" style="font-size:11px;color:var(--pink-400);margin-top:6px;display:none">
            <i class="fa-solid fa-circle-exclamation" style="margin-right:4px"></i>Please select an issue type.
          </p>
        </div>

        <!-- Description -->
        <div class="form-group">
          <label class="form-label" for="description">Description (optional)</label>
          <textarea class="form-control" id="description" name="description" placeholder="Describe the issue in detail — e.g. 'Bin at the gate has been overflowing since Monday…'" rows="3"></textarea>
        </div>

        <!-- Photo Upload -->
        <div class="form-group">
          <label class="form-label">Photo Evidence</label>
          <div class="photo-upload" id="photo-drop" onclick="document.getElementById('photo-input').click()">
            <i class="fa-solid fa-camera" id="photo-icon"></i>
            <span id="photo-label">Tap to upload photo</span>
          </div>
          <input type="file" id="photo-input" accept="image/*" capture="environment" style="display:none" onchange="handlePhotoSelect(this)">
          <img id="photo-preview" src="" alt="Preview" style="display:none;width:100%;border-radius:13px;margin-top:10px;max-height:210px;object-fit:cover;border:1px solid var(--border-normal)">
        </div>

        <!-- Location -->
        <div class="form-group">
          <label class="form-label">Location</label>
          <div class="location-display">
            <i class="fa-solid fa-location-dot pin"></i>
            <span id="location-text" style="flex:1;font-size:13px;color:var(--text-secondary)">Detecting GPS location…</span>
            <span class="spinner" id="loc-spinner"></span>
          </div>
          <input type="hidden" id="location-value" name="location">
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn-primary btn-lg" id="submit-btn">
          <i class="fa-solid fa-paper-plane"></i>
          Submit Report
        </button>

      </form>

    </div><!-- /#report-form-wrapper -->
  </div><!-- /.citizen-body -->
</div><!-- /.citizen-shell -->

<script src="/js/citizen.js"></script>
<%- include('partials/foot') %>
