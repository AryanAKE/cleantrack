<%- include('partials/head', { title: 'Welcome', description: 'CleanTrack — Smart Waste Collection Verification System' }) %>

<div class="login-page">

  <!-- ── LEFT PANEL: Brand Hero ─────────────────────────────── -->
  <div class="login-left">
    <div class="login-left-bg">
      <div class="login-left-orb orb-1"></div>
      <div class="login-left-orb orb-2"></div>
      <div class="login-left-orb orb-3"></div>
    </div>

    <div class="login-left-content">
      <div class="login-logo">
        <i class="fa-solid fa-recycle"></i>
      </div>
      <h1 class="login-brand">CleanTrack</h1>
      <p class="login-tagline">Smart Waste Collection · Verification Platform</p>

      <div class="login-features stagger">
        <div class="login-feature">
          <div class="login-feature-icon" style="background:rgba(139,92,246,.15);color:var(--violet-400)">
            <i class="fa-solid fa-qrcode"></i>
          </div>
          <div class="login-feature-text">
            <strong>QR-Based Verification</strong>
            Every bin scan creates a tamper-proof proof of collection.
          </div>
        </div>
        <div class="login-feature">
          <div class="login-feature-icon" style="background:rgba(6,182,212,.15);color:var(--cyan-400)">
            <i class="fa-solid fa-satellite-dish"></i>
          </div>
          <div class="login-feature-text">
            <strong>GPS Route Tracking</strong>
            Real-time fleet location pinned against planned routes.
          </div>
        </div>
        <div class="login-feature">
          <div class="login-feature-icon" style="background:rgba(251,191,36,.12);color:var(--amber-400)">
            <i class="fa-solid fa-chart-line"></i>
          </div>
          <div class="login-feature-text">
            <strong>Live Admin Dashboard</strong>
            Monitor completion rates, complaints, and truck status.
          </div>
        </div>
        <div class="login-feature">
          <div class="login-feature-icon" style="background:rgba(244,114,182,.12);color:var(--pink-400)">
            <i class="fa-solid fa-bullhorn"></i>
          </div>
          <div class="login-feature-text">
            <strong>Citizen Reporting</strong>
            Public portal for overflowing bins and missed collections.
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── RIGHT PANEL: Role Selector ────────────────────────── -->
  <div class="login-right">
    <div class="animate-fade-up">
      <h2 class="login-right-title">Select your role</h2>
      <p class="login-right-sub">Choose the portal that matches your access level to continue.</p>

      <!-- Admin -->
      <a href="/admin" class="role-btn admin">
        <div class="role-btn-icon">
          <i class="fa-solid fa-gauge-high"></i>
        </div>
        <div class="role-btn-info">
          <div class="role-btn-label">Control Center</div>
          <div class="role-btn-title">Admin Portal</div>
          <div class="role-btn-desc">Live fleet map, KPIs, and complaint management</div>
        </div>
        <i class="fa-solid fa-chevron-right role-btn-arrow"></i>
      </a>

      <!-- Collector -->
      <a href="/collector" class="role-btn collector">
        <div class="role-btn-icon">
          <i class="fa-solid fa-truck-fast"></i>
        </div>
        <div class="role-btn-info">
          <div class="role-btn-label">Field Operations</div>
          <div class="role-btn-title">Collector App</div>
          <div class="role-btn-desc">Scan bins, capture photos, and verify GPS</div>
        </div>
        <i class="fa-solid fa-chevron-right role-btn-arrow"></i>
      </a>

      <!-- Citizen -->
      <a href="/citizen" class="role-btn citizen">
        <div class="role-btn-icon">
          <i class="fa-solid fa-bullhorn"></i>
        </div>
        <div class="role-btn-info">
          <div class="role-btn-label">Public Access</div>
          <div class="role-btn-title">Citizen Report</div>
          <div class="role-btn-desc">Report overflowing or missed garbage bins</div>
        </div>
        <i class="fa-solid fa-chevron-right role-btn-arrow"></i>
      </a>

      <p style="text-align:center;font-size:11px;color:var(--text-tertiary);margin-top:30px">
        <i class="fa-solid fa-shield-halved" style="color:var(--violet-500);margin-right:5px"></i>
        Secured by CleanTrack &nbsp;·&nbsp; v2.0
      </p>
    </div>
  </div>

</div>

<%- include('partials/foot') %>
