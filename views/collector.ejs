<%- include('partials/head', { title: 'Collector App' }) %>

<div class="collector-shell">

  <!-- ── HEADER ──────────────────────────────────────────────── -->
  <div class="collector-header">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="sidebar-avatar" style="width:42px;height:42px;font-size:16px">R</div>
        <div>
          <div style="font-size:9px;color:var(--violet-400);font-weight:700;text-transform:uppercase;letter-spacing:1px">Driver</div>
          <div style="font-size:18px;font-weight:700;color:var(--text-primary);letter-spacing:-.4px;font-family:'Space Grotesk',sans-serif">Rajesh Kumar</div>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span class="badge-live"><span class="live-dot"></span> On Shift</span>
        <a href="/" class="btn btn-danger btn-sm"><i class="fa-solid fa-right-from-bracket"></i> End Shift</a>
      </div>
    </div>

    <!-- Stats Row -->
    <div class="collector-stats-row">
      <div class="collector-stat">
        <div class="collector-stat-value green" id="hdr-done"><%= doneCount %></div>
        <div class="collector-stat-label">Collected</div>
      </div>
      <div class="collector-stat">
        <div class="collector-stat-value" id="hdr-total"><%= totalCount %></div>
        <div class="collector-stat-label">Total</div>
      </div>
      <div class="collector-stat">
        <div class="collector-stat-value violet" id="hdr-time">--:--</div>
        <div class="collector-stat-label">Time</div>
      </div>
    </div>
  </div>

  <!-- ── BODY ────────────────────────────────────────────────── -->
  <div class="collector-body">

    <% if (!currentBin) { %>
      <!-- ALL DONE STATE -->
      <div style="text-align:center;padding:64px 20px">
        <div style="width:90px;height:90px;background:var(--grad-brand);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:38px;color:white;margin:0 auto 22px;box-shadow:0 0 40px rgba(139,92,246,.4)">
          <i class="fa-solid fa-trophy"></i>
        </div>
        <h2 style="font-size:24px;font-weight:700;color:var(--text-primary);margin-bottom:8px;font-family:'Space Grotesk',sans-serif">All Bins Collected!</h2>
        <p style="color:var(--text-secondary);font-size:14px;margin-bottom:26px">Excellent work — route complete for today.</p>
        <button class="btn btn-secondary" onclick="resetAllBins()">
          <i class="fa-solid fa-rotate-right"></i> Reset Demo
        </button>
      </div>
    <% } else { %>

      <h3 style="font-size:10px;font-weight:700;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:1px;margin-bottom:14px">Current Assignment</h3>

      <!-- TASK CARD -->
      <div class="task-card" id="task-card">
        <div class="task-card-header">
          <span class="badge badge-info">
            <i class="fa-solid fa-qrcode" style="margin-right:4px"></i>
            <%= currentBin.id %>
          </span>
          <span style="font-size:12px;font-weight:600;color:var(--text-tertiary)">
            <i class="fa-solid fa-location-arrow" style="color:var(--cyan-400);margin-right:4px"></i>
            <span id="bin-distance"><%= currentBin.distance %></span>
          </span>
        </div>

        <div class="task-location">
          <div class="task-location-name" id="bin-location"><%= currentBin.location %></div>
          <div class="task-location-sub" id="bin-area"><%= currentBin.area %></div>
        </div>

        <!-- SCAN AREA -->
        <div class="scan-area" id="scan-area" onclick="startCollectionFlow()">

          <!-- State: Idle -->
          <div class="scan-state" id="state-idle">
            <div style="width:68px;height:68px;background:rgba(139,92,246,.08);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:14px;border:2px solid rgba(139,92,246,.2)">
              <i class="fa-solid fa-qrcode" style="font-size:28px;color:var(--violet-400)"></i>
            </div>
            <p style="font-size:14px;font-weight:600;color:var(--text-secondary)">Tap to Scan Bin QR</p>
            <p style="font-size:11px;color:var(--text-tertiary);margin-top:5px">Align camera over the QR code</p>
          </div>

          <!-- State: Scanning -->
          <div class="scan-state hidden" id="state-scanning">
            <img src="/assets/dustbin.jpg" class="w-full h-full object-cover" style="position:absolute;inset:0;opacity:.65" alt="Bin">
            <div class="scanner-beam"></div>
            <div class="scanner-corners">
              <div class="scanner-corner tl"></div>
              <div class="scanner-corner tr"></div>
              <div class="scanner-corner bl"></div>
              <div class="scanner-corner br"></div>
            </div>
            <div style="position:absolute;bottom:14px;font-size:11px;color:white;font-family:monospace;letter-spacing:2px;text-shadow:0 1px 4px rgba(0,0,0,.8)">SCANNING BIN...</div>
          </div>

          <!-- State: Photo Capture -->
          <div class="scan-state hidden" id="state-photo">
            <img src="/assets/dustbin.jpg" class="w-full h-full object-cover" style="position:absolute;inset:0;filter:brightness(.75)" alt="Bin">
            <div style="position:absolute;bottom:0;width:100%;padding:20px;background:linear-gradient(to top,rgba(0,0,0,.8),transparent);display:flex;justify-content:center">
              <div style="width:54px;height:54px;border:4px solid rgba(255,255,255,.9);border-radius:50%;display:flex;align-items:center;justify-content:center">
                <div style="width:40px;height:40px;background:white;border-radius:50%;animation:pulseDot .8s ease infinite"></div>
              </div>
            </div>
            <div style="position:absolute;top:14px;right:14px;background:rgba(0,0,0,.65);border-radius:8px;padding:5px 11px;font-size:11px;font-weight:700;color:white">📷 Capturing...</div>
          </div>

          <!-- State: Success -->
          <div class="scan-state hidden success-overlay" id="state-success">
            <div class="success-check">
              <i class="fa-solid fa-check"></i>
            </div>
            <h3 style="font-size:22px;font-weight:700;color:white;margin-bottom:4px;font-family:'Space Grotesk',sans-serif">Verified!</h3>
            <p style="font-size:13px;color:rgba(255,255,255,.7);margin-bottom:22px">GPS & Photo matched successfully</p>
            <button id="next-bin-btn" class="btn"
              style="background:rgba(255,255,255,.18);color:white;border:2px solid rgba(255,255,255,.35);font-size:14px;padding:12px 30px;border-radius:12px;backdrop-filter:blur(8px)"
              onclick="loadNextBin(event)">
              Next Bin <i class="fa-solid fa-arrow-right"></i>
            </button>
          </div>

        </div><!-- /.scan-area -->

        <div style="text-align:center;margin-top:12px">
          <p style="font-size:11px;color:var(--text-tertiary)" id="status-text">Step 1: Tap the area above to scan the bin QR code.</p>
        </div>
      </div><!-- /.task-card -->

      <!-- QUEUE LIST -->
      <% if (bins.length > 1) { %>
        <h3 style="font-size:10px;font-weight:700;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:1px;margin:24px 0 12px">
          Up Next — <%= bins.length - 1 %> remaining
        </h3>
        <div id="queue-list">
          <% bins.slice(1).forEach((bin, i) => { %>
            <div class="queue-item" id="queue-<%= bin.id %>">
              <div class="queue-number"><%= i + 2 %></div>
              <div class="queue-info">
                <div class="queue-name"><%= bin.location %></div>
                <div class="queue-meta"><%= bin.id %> &nbsp;·&nbsp; <%= bin.area %></div>
              </div>
              <div class="queue-dist"><i class="fa-solid fa-location-arrow" style="margin-right:4px"></i><%= bin.distance %></div>
            </div>
          <% }) %>
        </div>
      <% } %>

    <% } %><!-- end if currentBin -->

  </div><!-- /.collector-body -->
</div><!-- /.collector-shell -->

<!-- Pass server data to JS -->
<script>
  window.BINS_DATA = <%- JSON.stringify(bins) %>;
  window.DONE_COUNT = <%= doneCount %>;
  window.TOTAL_COUNT = <%= totalCount %>;
</script>
<script src="/js/collector.js"></script>
<%- include('partials/foot') %>
