<%- include('partials/head', { title: 'Admin Dashboard' }) %>

<div class="app-shell">
  <%- include('partials/sidebar', { active: 'dashboard', pendingReportCount: pendingReportCount }) %>

  <div class="main-content">

    <!-- ── PAGE HEADER ────────────────────────────────────────── -->
    <div class="page-header">
      <div class="page-header-left">
        <h1 class="page-title">Live Dashboard</h1>
        <p class="page-subtitle" id="date-display">Loading date...</p>
      </div>
      <div class="flex items-center gap-3">
        <span class="badge-live"><span class="live-dot"></span> Live</span>
        <button class="btn btn-secondary btn-sm" onclick="refreshStats()">
          <i class="fa-solid fa-rotate-right"></i> Refresh
        </button>
        <a href="/" class="btn btn-danger btn-sm">
          <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
      </div>
    </div>

    <!-- ── PAGE BODY ──────────────────────────────────────────── -->
    <div class="page-body">

      <!-- KPI STATS GRID -->
      <div class="stats-grid stagger" id="stats-grid">

        <div class="stat-card green">
          <div class="stat-icon green"><i class="fa-solid fa-route"></i></div>
          <div class="stat-label">Route Completion</div>
          <div class="stat-value" id="stat-route"><%= stats.routeCompletion %>%</div>
          <div class="progress-bar">
            <div class="progress-fill green" style="width:<%= stats.routeCompletion %>%" id="prog-route"></div>
          </div>
          <div class="stat-trend up"><i class="fa-solid fa-arrow-trend-up"></i> +4% from yesterday</div>
        </div>

        <div class="stat-card red">
          <div class="stat-icon red"><i class="fa-solid fa-triangle-exclamation"></i></div>
          <div class="stat-label">Open Complaints</div>
          <div class="stat-value" style="color:var(--red-400)" id="stat-complaints"><%= stats.complaints %></div>
          <div class="progress-bar">
            <div class="progress-fill red" style="width:<%= Math.min(stats.complaints * 10, 100) %>%" id="prog-complaints"></div>
          </div>
          <div class="stat-trend down" id="complaints-trend">
            <i class="fa-solid fa-circle-exclamation"></i> Requires attention
          </div>
        </div>

        <div class="stat-card blue">
          <div class="stat-icon blue"><i class="fa-solid fa-truck"></i></div>
          <div class="stat-label">Trucks Active</div>
          <div class="stat-value" style="color:var(--blue-400)" id="stat-trucks"><%= stats.trucksActive %></div>
          <div class="progress-bar">
            <div class="progress-fill blue" style="width:80%"></div>
          </div>
          <div class="stat-trend up"><i class="fa-solid fa-signal"></i> All on-route</div>
        </div>

        <div class="stat-card amber">
          <div class="stat-icon amber"><i class="fa-solid fa-trash-can"></i></div>
          <div class="stat-label">Bins Collected Today</div>
          <div class="stat-value" style="color:var(--amber-400)" id="stat-bins"><%= stats.binsToday %></div>
          <div class="progress-bar">
            <div class="progress-fill amber" style="width:60%"></div>
          </div>
          <div class="stat-trend up"><i class="fa-solid fa-check-double"></i> GPS verified</div>
        </div>

      </div>

      <!-- MAIN CONTENT AREA: Map + Activity Feed -->
      <div class="admin-grid" id="fleet-map">

        <!-- GPS MAP -->
        <div class="card" style="margin-bottom:0">
          <div class="section-header" style="margin-bottom:16px">
            <h2 class="section-title"><i class="fa-solid fa-map-location-dot" style="color:var(--blue-400);margin-right:8px;font-size:13px"></i>Fleet GPS Map</h2>
            <span class="badge-live"><span class="live-dot"></span> Real-Time</span>
          </div>

          <div class="map-container">
            <div class="map-grid"></div>

            <!-- Roads -->
            <div class="map-road-h" style="top:33%"></div>
            <div class="map-road-h" style="top:66%"></div>
            <div class="map-road-v" style="left:33%"></div>
            <div class="map-road-v" style="left:66%"></div>

            <!-- Bin markers -->
            <div style="position:absolute;top:28%;left:40%;width:8px;height:8px;background:var(--emerald-400);border-radius:50%;border:2px solid white;box-shadow:0 0 6px rgba(16,185,129,0.8)"></div>
            <div style="position:absolute;top:55%;left:20%;width:8px;height:8px;background:var(--amber-400);border-radius:50%;border:2px solid white;box-shadow:0 0 6px rgba(245,158,11,0.8)"></div>
            <div style="position:absolute;top:72%;left:58%;width:8px;height:8px;background:var(--red-400);border-radius:50%;border:2px solid white;box-shadow:0 0 6px rgba(239,68,68,0.8)"></div>

            <!-- Truck 1 (active) -->
            <div class="map-truck" style="top:30%;left:35%">
              <div class="map-truck-pulse" style="background:rgba(16,185,129,0.3)"></div>
              <div class="map-truck-icon" style="background:var(--emerald-600)">
                <i class="fa-solid fa-truck" style="font-size:11px"></i>
              </div>
              <div class="map-truck-label">Truck #802</div>
            </div>

            <!-- Truck 2 -->
            <div class="map-truck" style="bottom:26%;right:28%">
              <div class="map-truck-icon" style="background:var(--slate-600)">
                <i class="fa-solid fa-truck" style="font-size:11px"></i>
              </div>
              <div class="map-truck-label">Truck #404</div>
            </div>

            <!-- Truck 3 -->
            <div class="map-truck" style="top:15%;right:18%">
              <div class="map-truck-pulse" style="background:rgba(59,130,246,0.3)"></div>
              <div class="map-truck-icon" style="background:var(--blue-600)">
                <i class="fa-solid fa-truck" style="font-size:11px"></i>
              </div>
              <div class="map-truck-label">Truck #211</div>
            </div>

            <!-- Legend -->
            <div style="position:absolute;bottom:12px;left:12px;background:rgba(10,15,30,0.85);border:1px solid var(--border-subtle);border-radius:8px;padding:8px 12px;backdrop-filter:blur(8px)">
              <div style="font-size:10px;font-weight:700;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px">Legend</div>
              <div style="display:flex;gap:12px">
                <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:var(--emerald-400);font-weight:600"><span style="width:8px;height:8px;background:var(--emerald-400);border-radius:50%;display:inline-block"></span>Collected</div>
                <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:var(--amber-400);font-weight:600"><span style="width:8px;height:8px;background:var(--amber-400);border-radius:50%;display:inline-block"></span>In-Progress</div>
                <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:var(--red-400);font-weight:600"><span style="width:8px;height:8px;background:var(--red-400);border-radius:50%;display:inline-block"></span>Missed</div>
              </div>
            </div>
          </div>
        </div>

        <!-- ACTIVITY FEED -->
        <div class="card" style="margin-bottom:0">
          <div class="section-header">
            <h2 class="section-title"><i class="fa-solid fa-bolt" style="color:var(--amber-400);margin-right:8px;font-size:13px"></i>Live Verification Feed</h2>
            <span class="badge badge-neutral"><%= recentActivity.length %> events</span>
          </div>

          <div id="activity-feed">
            <% if (recentActivity.length === 0) { %>
              <div style="text-align:center;padding:32px 0;color:var(--text-tertiary);font-size:13px">
                <i class="fa-solid fa-clock-rotate-left" style="font-size:24px;margin-bottom:8px;display:block;opacity:.4"></i>
                No activity yet today
              </div>
            <% } else { %>
              <% recentActivity.forEach((bin, i) => { %>
                <div class="feed-item" style="animation-delay:<%= i * 0.05 %>s">
                  <div class="feed-icon" style="background:rgba(16,185,129,.12);color:var(--emerald-400)">
                    <i class="fa-solid fa-circle-check"></i>
                  </div>
                  <div class="feed-content">
                    <div class="feed-title"><%= bin.location %></div>
                    <div class="feed-meta">
                      <span class="badge badge-success" style="margin-right:4px">Verified</span>
                      <%= bin.id %> &nbsp;·&nbsp; GPS ✓ &nbsp;·&nbsp; Photo ✓
                    </div>
                  </div>
                  <div class="feed-time">
                    <% 
                      const diff = Math.round((Date.now() - new Date(bin.collectedAt).getTime()) / 60000);
                      const display = diff < 60 ? diff + 'm ago' : Math.round(diff/60) + 'h ago';
                    %>
                    <%= display %>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

      </div><!-- /.admin-grid -->

      <!-- REPORTS TABLE -->
      <div class="card" id="reports-section" style="margin-top:20px">
        <div class="section-header">
          <h2 class="section-title"><i class="fa-solid fa-triangle-exclamation" style="color:var(--red-400);margin-right:8px;font-size:13px"></i>Citizen Reports</h2>
          <div class="flex gap-2">
            <span class="badge badge-danger"><%= pendingReportCount %> pending</span>
            <a href="/citizen" class="btn btn-secondary btn-sm">+ New</a>
          </div>
        </div>

        <% if (reports.length === 0) { %>
          <div style="text-align:center;padding:40px 0;color:var(--text-tertiary);font-size:13px">
            <i class="fa-solid fa-inbox" style="font-size:28px;margin-bottom:8px;display:block;opacity:.3"></i>
            No reports submitted yet
          </div>
        <% } else { %>
          <div class="table-container">
            <table>
              <thead>
                <tr>
                  <th>Type</th>
                  <th>Description</th>
                  <th>Location</th>
                  <th>Status</th>
                  <th>Submitted</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="reports-tbody">
                <% reports.forEach(report => { %>
                  <tr id="row-<%= report.id %>">
                    <td>
                      <span class="badge <%= report.issueType === 'Overflowing Bin' ? 'badge-warning' : report.issueType === 'Missed Collection' ? 'badge-danger' : 'badge-neutral' %>">
                        <%= report.issueType %>
                      </span>
                    </td>
                    <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--text-secondary);font-size:12px">
                      <%= report.description || '—' %>
                    </td>
                    <td style="font-size:12px;color:var(--text-secondary)">
                      <i class="fa-solid fa-location-dot" style="color:var(--red-400);margin-right:4px"></i>
                      <%= report.location %>
                    </td>
                    <td>
                      <span class="badge <%= report.status === 'pending' ? 'badge-warning' : 'badge-success' %>" id="status-<%= report.id %>">
                        <%= report.status === 'pending' ? '⏳ Pending' : '✓ Resolved' %>
                      </span>
                    </td>
                    <td style="font-size:11px;color:var(--text-tertiary)">
                      <%= new Date(report.submittedAt).toLocaleString('en-IN', { dateStyle: 'short', timeStyle: 'short' }) %>
                    </td>
                    <td>
                      <% if (report.status === 'pending') { %>
                        <button class="btn btn-primary btn-sm" onclick="resolveReport('<%= report.id %>', this)">
                          Resolve
                        </button>
                      <% } else { %>
                        <span style="font-size:11px;color:var(--text-tertiary)">Closed</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

    </div><!-- /.page-body -->
  </div><!-- /.main-content -->
</div><!-- /.app-shell -->

<script src="/js/admin.js"></script>
<%- include('partials/foot') %>
